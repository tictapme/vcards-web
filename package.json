  },
  "homepage": "https://github.com/tictapme/vcards-web#readme",
  "devDependencies": {
    "@types/node": "^24.5.2",
    "astro": "^4.16.18",
    "cross-env": "^7.0.3",
    "fs": "0.0.1-security",
    "typescript": "^5.9.2"
  }
}
